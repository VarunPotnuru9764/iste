{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project",
    "description": "Projects maintained by SIGs"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "unique": true
    },
    "shortDescription": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "techStack": {
      "type": "json"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "In Progress",
        "Live"
      ],
      "default": "In Progress"
    },
    "year": {
      "type": "string"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "githubUrl": {
      "type": "string"
    },
    "demoUrl": {
      "type": "string"
    },
    "leads": {
      "type": "json"
    },
    "sig": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::sig.sig",
      "inversedBy": "projects",
      "required": true
    }
  }
}
